# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Create free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── PAYARC SANDBOX ────────────────────────────────────────────────────────────
# Sign up at https://payarc.net → request sandbox access
# Sandbox API base: https://testapi.payarc.net/v1
PAYARC_API_KEY=your_sandbox_bearer_token
PAYARC_API_URL=https://testapi.payarc.net/v1

# ─── SALESFORCE ───────────────────────────────────────────────────────────────
# Free Developer Edition: https://developer.salesforce.com/signup
# Create a Connected App (Setup → App Manager → New Connected App)
# Enable OAuth, add "Full access (full)" scope
SFDC_LOGIN_URL=https://login.salesforce.com
SFDC_CLIENT_ID=your_connected_app_consumer_key
SFDC_CLIENT_SECRET=your_connected_app_consumer_secret
SFDC_USERNAME=your@email.com
SFDC_PASSWORD=yourPasswordPlusSecurityToken
# Get security token: Setup → My Personal Information → Reset Security Token

# ─── TWILIO (WhatsApp) ────────────────────────────────────────────────────────
# Sign up at https://console.twilio.com → Messaging → Try it out → WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── ANTHROPIC (Claude AI for WhatsApp parsing) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── SITE ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
